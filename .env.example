# ── Variables de entorno requeridas para el proyecto ──
# Copia este archivo como .env.local y rellena los valores.
# En producción (Vercel), agrega estos valores desde el dashboard: 
# Settings > Environment Variables

# ── Cloudflare R2 (para generar URLs firmadas de PDFs) ──
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<tu_access_key_id>
R2_SECRET_ACCESS_KEY=<tu_secret_access_key>
R2_BUCKET_NAME=biblioteca-digital

# ── Vercel KV (Redis) para códigos de donadores ──
# Estos se autocompletan al conectar una base KV desde el dashboard de Vercel.
KV_URL=<url de tu Vercel KV>
KV_REST_API_URL=<api url de tu Vercel KV>
KV_REST_API_TOKEN=<token de tu Vercel KV>
KV_REST_API_READ_ONLY_TOKEN=<read-only token>

# ── Seguridad: firma de cookies de donadores ──
# Usa una cadena aleatoria larga y secreta (mín. 32 caracteres).
DONOR_COOKIE_SECRET=cambia_esto_por_una_cadena_secreta_muy_larga

# ── API Key del Recomendador IA (ya existente) ──
GEMINI_API_KEY=<tu_api_key_de_gemini>
